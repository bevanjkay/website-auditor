{
  "name": "website-auditor",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "bump:version": "node scripts/bump-version.mjs",
    "check:playwright": "node scripts/check-playwright-version.mjs",
    "lint": "pnpm check:playwright && eslint .",
    "lint:fix": "pnpm check:playwright && eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.1",
    "@types/node": "^25.6.0",
    "@types/nspell": "^2.1.6",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}

{
  "name": "@website-auditor/db",
  "type": "module",
  "version": "0.1.0",
  "exports": {
    ".": {
      "types": "./dist/packages/db/src/index.d.ts",
      "default": "./dist/packages/db/src/index.js"
    }
  },
  "main": "./dist/packages/db/src/index.js",
  "types": "./dist/packages/db/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
